APP_ENV=dev
APP_DEBUG=1
APP_SECRET=example-symfony-dev-secret-change-me

# ErrorWatch — copy a project API key from the dashboard
ERRORWATCH_ENABLED=true
ERRORWATCH_ENDPOINT=http://localhost:3333
ERRORWATCH_API_KEY=change-me
ERRORWATCH_RELEASE=example-symfony-dev

# Symfony Messenger — uses the existing Doctrine connection for the async queue
MESSENGER_TRANSPORT_DSN=doctrine://default?queue_name=default
