{
    "name": "errorwatch/example-symfony",
    "description": "Minimal Symfony API skeleton that exercises the ErrorWatch SDK (errors, APM spans, cache, logs, distributed tracing).",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "doctrine/dbal": "^3.8|^4.0",
        "doctrine/doctrine-bundle": "^2.12",
        "doctrine/orm": "^3.0",
        "errorwatch/sdk-php": "@dev",
        "monolog/monolog": "^3.0",
        "symfony/cache": "^7.0|^8.0",
        "symfony/console": "^7.0|^8.0",
        "symfony/dotenv": "^7.0|^8.0",
        "symfony/framework-bundle": "^7.0|^8.0",
        "symfony/doctrine-messenger": "^7.0|^8.0",
        "symfony/http-client": "^7.0|^8.0",
        "symfony/messenger": "^7.0|^8.0",
        "symfony/monolog-bundle": "^3.10",
        "symfony/runtime": "^7.0|^8.0",
        "symfony/var-exporter": "^7.1",
        "symfony/yaml": "^7.0|^8.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/errorwatch-sdk-php",
            "options": { "symlink": true }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "symfony/flex": false
        },
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "require": "^7.0|^8.0"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
