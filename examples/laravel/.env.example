APP_NAME=ErrorWatch-Laravel-Example
APP_ENV=local
APP_KEY=base64:REPLACE_WITH_GENERATED_KEY
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# ErrorWatch SDK Configuration
ERRORWATCH_ENABLED=true
ERRORWATCH_ENDPOINT=http://localhost:3333
ERRORWATCH_API_KEY=ew_test_xxx

# Optional
ERRORWATCH_LOGGING_ENABLED=true
ERRORWATCH_LOG_LEVEL=error
ERRORWATCH_EXCEPTIONS_ENABLED=true
ERRORWATCH_REPLAY_ENABLED=false
