{
  "name": "errorwatch",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "turbo run dev:standalone --filter=@apps/api --filter=@apps/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:push": "turbo run db:push --filter=@apps/api"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "overrides": {
    "better-sqlite3": "npm:empty-npm-package@1.0.0"
  },
  "packageManager": "bun@1.3.9"
}
