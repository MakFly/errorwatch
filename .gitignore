# Dependencies
node_modules/

# Logs
logs/
*.log
!apps/web/src/**/logs/
!apps/web/src/**/logs/*.tsx

# Dev PID files
.dev-pids

# IDE
.idea/
.vscode/

# Playwright MCP (Cursor)
.playwright-mcp/

# CodeLens
.codelens*

# OS
.DS_Store

# Environment files - NEVER commit secrets
.env
.env.local
.env.*.local
.env.development
.env.production
*.key
*.pem

# Database
*.db
*.sqlite
*.sqlite3

# Build artifacts
dist/
.next/
.turbo/

# Test coverage
coverage/

# SDK packages (separate repos via subtree split or worktrees)
# See: github.com/MakFly/errorwatch-sdk-symfony
# See: github.com/MakFly/errorwatch-sdk-laravel
packages/

# Shared bare clones backing the worktree layout (see scripts/sdk-worktree.sh)
.git-bare/

# Example projects — build artefacts only (the source IS tracked)
examples/*/vendor/
examples/*/var/cache/
examples/*/var/log/
examples/*/composer.lock
!examples/laravel-api/composer.lock

# instant-grep index
.ig/
